# Copy to .env.local and fill in.

# Oura Ring API token. Required for the /health module.
# Get one at https://cloud.ouraring.com/personal-access-tokens
OURA_TOKEN=

# Optional: directory of markdown books for the /library module.
# Each book lives in its own subdirectory with a book.json + chapter .md files.
# Defaults to $HOME/Projects/dashboard-me-library if unset.
LIBRARY_PATH=
